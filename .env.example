# Kopieren nach ".env" und ausfuellen. ".env" NIEMALS committen.

# --- Telegram Bot ---
# TELEGRAM_BOT_TOKEN: bei @BotFather in Telegram per /newbot erzeugen.
# Sieht aus wie: 123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=hier-bot-token-von-botfather-eintragen

# TELEGRAM_CHAT_ID: die feste, einzige Person, an die dieser Server jemals
# schreiben kann -- es gibt bewusst keinen Weg, ueber die Tools eine andere
# chat_id anzugeben.
#
# So bekommst du die chat_id:
#   1. Bot in Telegram suchen (Name/Username, den du bei @BotFather vergeben
#      hast) und ihm eine beliebige Nachricht schicken (z.B. "hi").
#   2. Im Browser aufrufen (mit deinem echten Token):
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Im JSON nach "chat":{"id": ...} suchen -- diese Zahl ist die chat_id.
TELEGRAM_CHAT_ID=hier-chat-id-eintragen

# --- Absicherung des MCP-Endpunkts ---
# Langes zufaelliges Geheimnis, das Claude beim Verbinden mitschicken muss.
# Erzeugen z.B. mit: openssl rand -hex 32
MCP_AUTH_TOKEN=hier-langes-zufaelliges-token-eintragen

# Lokaler Port, den docker-compose auf 127.0.0.1 published (siehe docker-compose.yml).
# Standard 8001, damit es neben Ida-Untis (8000) auf demselben Server laufen kann.
MCP_PORT=8001

# --- Automatisches Antworten (Claude API) ---
# Sobald die konfigurierte Person (TELEGRAM_CHAT_ID) dem Bot schreibt, liest
# der Server die neue(n) Nachricht(en) und laesst Claude automatisch
# antworten -- unabhaengig vom MCP-Tool oben, laeuft als Hintergrund-Prozess
# im selben Container. Auf false setzen, um nur das reine nachricht_senden-
# MCP-Tool zu nutzen (kein automatisches Antworten).
AUTOREPLY_ENABLED=true

# API-Key fuer die Claude/Anthropic-Routine (console.anthropic.com -> API Keys).
# Nur noetig, wenn AUTOREPLY_ENABLED=true.
ANTHROPIC_API_KEY=hier-anthropic-api-key-eintragen

# Modell fuer die automatischen Antworten.
CLAUDE_MODEL=claude-opus-4-8

# Wie gruendlich/teuer Claude nachdenkt: low, medium, high, xhigh oder max.
CLAUDE_EFFORT=medium

# System-Prompt fuer die automatischen Antworten -- frei anpassbar.
CLAUDE_SYSTEM_PROMPT=Du antwortest automatisch auf Telegram-Nachrichten fuer den Kontobesitzer. Antworte kurz, freundlich und hilfreich auf Deutsch. Wenn du etwas nicht sicher beantworten kannst, sag das ehrlich statt zu raten.

# Sekunden, die nach der letzten Nachricht gewartet wird, bevor geantwortet
# wird -- buendelt schnell hintereinander geschickte Nachrichten zu einer
# Antwort statt mehrfach einzeln zu reagieren.
AUTOREPLY_DEBOUNCE_SECONDS=3

# --- Nur fuer docker-compose (Image-Referenz aus GHCR) ---
# Dein GitHub-Benutzername/-Organisation in Kleinbuchstaben.
GITHUB_OWNER=l8tenever
IMAGE_TAG=latest
