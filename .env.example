# Kopieren nach ".env" und ausfuellen. ".env" NIEMALS committen.

# --- Telegram Bot ---
# TELEGRAM_BOT_TOKEN: bei @BotFather in Telegram per /newbot erzeugen.
# Sieht aus wie: 123456789:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=hier-bot-token-von-botfather-eintragen

# TELEGRAM_CHAT_ID: die feste, einzige Person, an die dieser Server jemals
# schreiben kann -- es gibt bewusst keinen Weg, ueber die Tools eine andere
# chat_id anzugeben.
#
# So bekommst du die chat_id:
#   1. Bot in Telegram suchen (Name/Username, den du bei @BotFather vergeben
#      hast) und ihm eine beliebige Nachricht schicken (z.B. "hi").
#   2. Im Browser aufrufen (mit deinem echten Token):
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#   3. Im JSON nach "chat":{"id": ...} suchen -- diese Zahl ist die chat_id.
TELEGRAM_CHAT_ID=hier-chat-id-eintragen

# --- Absicherung des MCP-Endpunkts ---
# Langes zufaelliges Geheimnis, das Claude beim Verbinden mitschicken muss.
# Erzeugen z.B. mit: openssl rand -hex 32
MCP_AUTH_TOKEN=hier-langes-zufaelliges-token-eintragen

# Lokaler Port, den docker-compose auf 127.0.0.1 published (siehe docker-compose.yml).
# Standard 4567, damit es neben Ida-Untis (8000) auf demselben Server laufen kann.
MCP_PORT=4567

# --- Automatisches Antworten (claude.ai Routine) ---
# Sobald die konfigurierte Person (TELEGRAM_CHAT_ID) dem Bot schreibt,
# triggert der Server eine claude.ai Routine ueber deren eigenen API-Token.
# Die Routine liest die Nachricht dann selbst ueber das MCP-Tool
# neue_nachrichten_abrufen und antwortet ueber nachricht_senden -- dieser
# Container ruft selbst keine Claude-API auf. Auf false setzen, um nur das
# reine nachricht_senden-MCP-Tool zu nutzen (kein automatisches Antworten).
AUTOREPLY_ENABLED=true

# In claude.ai eine neue Routine anlegen (claude.ai -> Routinen -> Neue
# Routine), als Trigger "API" waehlen -- dabei bekommst du einen Token
# angezeigt (sk-ant-oat01-...). Die Routine-ID (trig_...) steht in der URL,
# die dir claude.ai beim Bearbeiten der Routine anzeigt.
ROUTINE_ID=hier-routine-id-eintragen-z.B.-trig_xxx
ROUTINE_API_KEY=hier-api-token-von-der-routine-eintragen

# Sekunden, die nach der letzten Nachricht gewartet wird, bevor die Routine
# getriggert wird -- buendelt schnell hintereinander geschickte Nachrichten
# zu einem Lauf statt die Routine mehrfach hintereinander zu starten.
AUTOREPLY_DEBOUNCE_SECONDS=3

# Pfad fuer das persistente Gedaechtnis-File (Tools gedaechtnis_lesen/
# gedaechtnis_schreiben) -- normalerweise nicht aendern, liegt auf dem
# in docker-compose.yml definierten Volume und bleibt so ueber Neustarts
# erhalten.
MEMORY_FILE_PATH=/data/memory.md

# --- Nur fuer docker-compose (Image-Referenz aus GHCR) ---
# Dein GitHub-Benutzername/-Organisation in Kleinbuchstaben.
GITHUB_OWNER=l8tenever
IMAGE_TAG=latest
